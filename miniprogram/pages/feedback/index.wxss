.feedback-screen {
  padding-bottom: 80rpx;
}

.question-card {
  position: relative;
  margin-top: 26rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid #e6ddd6;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(70, 52, 41, 0.05);
}

.question-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.question-number {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f9e9e6;
  color: #be3a32;
  font-size: 22rpx;
  font-weight: 700;
}

.question-title {
  flex: 1;
  min-width: 0;
  color: #2b2724;
  font-size: 29rpx;
  font-weight: 650;
  line-height: 1.55;
}

.feedback-textarea {
  width: 100%;
  height: 220rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border: 2rpx solid #dfd5ce;
  border-radius: 16rpx;
  background: #faf8f6;
  color: #3f3935;
  font-size: 24rpx;
  line-height: 1.65;
}

.feedback-textarea-compact {
  height: 168rpx;
}

.character-count {
  margin-top: 10rpx;
  color: #9a918a;
  font-size: 20rpx;
  text-align: right;
}

.privacy-note {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  border-radius: 15rpx;
  background: #ece7e2;
  color: #766e68;
  font-size: 21rpx;
  line-height: 1.65;
}

.feedback-actions {
  margin-top: 28rpx;
}
