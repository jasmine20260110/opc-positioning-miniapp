.question-screen {
  padding-bottom: 48rpx;
}

.question-meta {
  display: flex;
  margin-top: 22rpx;
  justify-content: space-between;
  color: #7d746d;
  font-size: 23rpx;
}

.progress-track {
  width: 100%;
  height: 10rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e3dad3;
}

.progress-value {
  height: 100%;
  border-radius: 999rpx;
  background: #c83f36;
  transition: width 0.25s ease;
}

.question-card {
  min-height: 740rpx;
  margin-top: 34rpx;
  padding: 38rpx 32rpx;
  border: 1rpx solid #e3dbd4;
  border-radius: 28rpx;
  background: #ffffff;
}

.module-tag {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f7e8e5;
  color: #b43731;
  font-size: 20rpx;
  font-weight: 600;
  text-transform: uppercase;
}

.question-title {
  margin-top: 28rpx;
  color: #25211f;
  font-size: 38rpx;
  font-weight: 650;
  line-height: 1.55;
}

.question-intent {
  margin-top: 20rpx;
  color: #857c75;
  font-size: 24rpx;
  line-height: 1.6;
}

.answer-input {
  width: 100%;
  height: 300rpx;
  margin-top: 32rpx;
  padding: 26rpx;
  border: 2rpx solid #ddd3cb;
  border-radius: 18rpx;
  background: #fbf9f7;
  color: #312d2a;
  font-size: 28rpx;
  line-height: 1.7;
}

.mixed-input {
  height: 180rpx;
  margin-top: 20rpx;
}

.option-list {
  display: flex;
  margin-top: 30rpx;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  align-items: center;
  border: 2rpx solid #dfd7d0;
  border-radius: 18rpx;
  background: #fbfaf8;
  color: #4c4641;
  line-height: 1.5;
  gap: 18rpx;
}

.option-active {
  border-color: #c83f36;
  background: #fff1ef;
  color: #9f302a;
}

.option-dot {
  width: 20rpx;
  height: 20rpx;
  flex: 0 0 auto;
  border: 3rpx solid #cfc4bc;
  border-radius: 50%;
}

.option-active .option-dot {
  border: 6rpx solid #c83f36;
  background: #ffffff;
}

.input-note {
  margin-top: 16rpx;
  color: #9a9189;
  font-size: 21rpx;
}

.suggestion {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #fff4db;
  color: #84611c;
  font-size: 23rpx;
  line-height: 1.6;
}

.question-actions {
  display: flex;
  margin-top: 28rpx;
  gap: 20rpx;
}

.half-button {
  flex: 1;
}
