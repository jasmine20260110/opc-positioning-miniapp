page {
  overflow: hidden;
  background: #ffffff;
}

.intro-page {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.intro-artboard {
  position: relative;
  width: 100vw;
  height: 166.74vw;
  max-width: 59.97vh;
  max-height: 100vh;
}

.intro-image {
  width: 100%;
  height: 100%;
}

.intro-enter-button {
  position: absolute;
  right: 1.8%;
  bottom: 2.9%;
  left: 8.6%;
  height: 7.2%;
  border: 0;
  background: transparent;
  opacity: 0;
}

.intro-enter-button::after {
  border: 0;
}
