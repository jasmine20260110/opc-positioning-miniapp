page {
  overflow: hidden;
  background: #ffffff;
}

.intro-page {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.intro-artboard {
  position: relative;
  width: 100vw;
  height: 176.88vw;
  max-width: 56.53vh;
  max-height: 100vh;
}

.intro-image {
  width: 100%;
  height: 100%;
}

.intro-enter-button {
  position: absolute;
  right: 6.8%;
  bottom: 5.8%;
  left: 6.8%;
  height: 9.5%;
  border: 0;
  background: transparent;
  opacity: 0;
}

.intro-enter-button::after {
  border: 0;
}
