<view class="home-screen">
  <view class="home-content">
    <image class="home-logo" src="/images/home-logo.svg" mode="aspectFit" />

    <view class="home-title">OPC定位神器</view>
    <view class="home-methodology">
      <text>五种时间 · 以</text><text class="home-methodology-accent">心流时间</text><text>为切入口</text>
    </view>
    <view class="home-subtitle">探索你的优势与定位</view>

    <view class="gold-divider">
      <view class="gold-divider-line"></view>
      <view class="gold-divider-dot"></view>
      <view class="gold-divider-line"></view>
    </view>
    <view class="home-slogan">找到你现在最值得尝试的方向</view>

    <view class="benefit-card">
      <view class="benefit-row">
        <view class="benefit-icon-wrap">
          <image class="benefit-icon" src="/images/home-clock.svg" mode="aspectFit" />
        </view>
        <view class="benefit-copy">
          <view class="benefit-main"><text class="benefit-accent">≤15分钟</text></view>
          <view class="benefit-note">梳理热爱 × 擅长 × 市场</view>
        </view>
      </view>

      <view class="benefit-separator"></view>

      <view class="benefit-row">
        <view class="benefit-icon-wrap">
          <image class="benefit-icon" src="/images/home-route.svg" mode="aspectFit" />
        </view>
        <view class="benefit-copy">
          <view class="benefit-main">获得<text class="benefit-accent benefit-number">3</text>条候选路线</view>
        </view>
      </view>

      <view class="benefit-separator"></view>

      <view class="benefit-row">
        <view class="benefit-icon-wrap">
          <image class="benefit-icon" src="/images/home-calendar.svg" mode="aspectFit" />
        </view>
        <view class="benefit-copy">
          <view class="benefit-main">开启<text class="benefit-accent benefit-number">7</text>天验证行动</view>
        </view>
      </view>
    </view>

    <button class="main-button home-start-button" bindtap="onStart">开始探索</button>
    <button class="home-report-link" bindtap="onViewReport">
      <text>已有报告？查看我的报告</text>
      <text class="report-arrow">→</text>
    </button>

    <button
      class="secondary-button home-demo-button"
      loading="{{demoStarting}}"
      disabled="{{demoStarting}}"
      bindtap="onUseDemo"
    >使用示例数据</button>
  </view>
</view>
