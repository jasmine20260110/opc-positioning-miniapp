.landing-screen {
  padding-top: 72rpx;
}

.brand-pill {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border: 1rpx solid #d9aea8;
  border-radius: 999rpx;
  background: #f9e9e6;
  color: #a93630;
  font-size: 20rpx;
  font-weight: 650;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 38rpx;
  color: #201d1b;
  font-size: 68rpx;
  font-weight: 750;
  letter-spacing: -2rpx;
}

.hero-formula {
  margin-top: 18rpx;
  color: #be3a32;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-copy {
  margin-top: 28rpx;
  color: #6f6862;
  font-size: 28rpx;
  line-height: 1.8;
}

.result-card {
  margin-top: 48rpx;
  padding: 34rpx 32rpx;
  border: 1rpx solid #e3dad2;
  border-radius: 28rpx;
  background: #fffdfb;
}

.result-card-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 650;
}

.result-item {
  display: flex;
  padding: 26rpx 0;
  align-items: flex-start;
  border-bottom: 1rpx solid #eee7e1;
  gap: 24rpx;
}

.result-item:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.result-index {
  color: #c83f36;
  font-size: 22rpx;
  font-weight: 700;
}

.result-name {
  font-size: 28rpx;
  font-weight: 600;
}

.result-note {
  margin-top: 8rpx;
  color: #847c75;
  font-size: 23rpx;
  line-height: 1.5;
}

.privacy-note {
  margin-top: 28rpx;
  color: #8d857e;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}
