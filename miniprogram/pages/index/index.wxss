page {
  background: #fffefd;
}

.home-screen {
  min-height: 100vh;
  padding: 156rpx 68rpx 30rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 2% 44%, rgba(244, 235, 220, 0.45), transparent 27%),
    radial-gradient(circle at 96% 52%, rgba(245, 237, 226, 0.38), transparent 29%),
    #fffefd;
}

.home-content {
  display: flex;
  width: 100%;
  max-width: 614rpx;
  margin: 0 auto;
  align-items: center;
  flex-direction: column;
  transform: translateY(200rpx);
}

.home-logo {
  width: 152rpx;
  height: 152rpx;
}

.home-title {
  margin-top: 27rpx;
  color: #151515;
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.home-subtitle {
  margin-top: 10rpx;
  color: #696662;
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
  line-height: 1.35;
}

.home-methodology {
  margin-top: 12rpx;
  color: #4f4b48;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1.35;
}

.home-methodology-accent {
  color: #d80051;
  font-weight: 700;
}

.gold-divider {
  display: flex;
  margin-top: 13rpx;
  align-items: center;
}

.gold-divider-line {
  width: 36rpx;
  height: 2rpx;
  background: #e5c98f;
}

.gold-divider-dot {
  width: 37rpx;
  height: 7rpx;
  border-radius: 99rpx;
  background: #d8a848;
}

.home-slogan {
  margin-top: 13rpx;
  color: #d5a24c;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  line-height: 1.45;
}

.benefit-card {
  width: 100%;
  margin-top: 28rpx;
  padding: 16rpx 34rpx;
  border: 1rpx solid rgba(230, 226, 220, 0.72);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 11rpx 31rpx rgba(82, 67, 51, 0.09);
}

.benefit-row {
  display: flex;
  min-height: 130rpx;
  align-items: center;
}

.benefit-icon-wrap {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  flex: 0 0 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fbf4e9;
}

.benefit-icon {
  width: 60rpx;
  height: 60rpx;
}

.benefit-copy {
  margin-left: 31rpx;
  color: #2b2927;
}

.benefit-main {
  font-size: 33rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1.35;
}

.benefit-accent {
  color: #df152a;
  font-size: 40rpx;
  font-weight: 700;
}

.benefit-number {
  margin: 0 5rpx;
}

.benefit-note {
  margin-top: 3rpx;
  color: #514e4a;
  font-size: 27rpx;
  letter-spacing: 1rpx;
  line-height: 1.35;
}

.benefit-separator {
  height: 1rpx;
  margin-left: 7rpx;
  background: #e9e5e0;
}

.home-start-button {
  width: 100%;
  height: 88rpx;
  margin-top: 30rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #e9162d 0%, #d91024 100%);
  box-shadow: 0 8rpx 18rpx rgba(211, 18, 37, 0.18);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 650;
  letter-spacing: 2rpx;
}

.home-start-button:active {
  opacity: 0.88;
}

.home-report-link {
  display: flex;
  width: auto;
  height: 57rpx;
  margin-top: 12rpx;
  align-items: center;
  justify-content: center;
  color: #696662;
  font-size: 27rpx;
  font-weight: 400;
  line-height: 1;
  text-decoration: underline;
  text-underline-offset: 7rpx;
}

.report-arrow {
  margin-left: 13rpx;
  font-size: 34rpx;
  text-decoration: none;
}

.proof-bar {
  display: flex;
  width: 100%;
  height: 76rpx;
  margin-top: 24rpx;
  padding: 0 22rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(235, 231, 226, 0.74);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 24rpx rgba(75, 63, 50, 0.08);
  white-space: nowrap;
}

.proof-item {
  display: flex;
  min-width: 0;
  align-items: center;
}

.proof-item-time {
  margin-left: 19rpx;
}

.proof-icon {
  width: 37rpx;
  height: 37rpx;
  margin-right: 10rpx;
  flex: 0 0 37rpx;
}

.proof-users-icon {
  width: 49rpx;
  flex-basis: 49rpx;
}

.proof-label {
  color: #595653;
  font-size: 23rpx;
  letter-spacing: 0;
}

.proof-number {
  margin: 0 4rpx;
  color: #dc1428;
  font-size: 31rpx;
  font-weight: 700;
}

.proof-separator {
  width: 1rpx;
  height: 39rpx;
  margin-left: 19rpx;
  background: #ded9d2;
}

@media (max-height: 650px) {
  .home-screen {
    padding-top: 54rpx;
    padding-bottom: 24rpx;
  }

  .home-logo {
    width: 132rpx;
    height: 132rpx;
  }

  .home-title {
    margin-top: 19rpx;
    font-size: 56rpx;
  }

  .gold-divider {
    margin-top: 16rpx;
  }

  .benefit-card {
    margin-top: 19rpx;
  }

  .benefit-row {
    min-height: 110rpx;
  }

  .home-start-button {
    margin-top: 22rpx;
  }

  .proof-bar {
    margin-top: 15rpx;
  }
}
