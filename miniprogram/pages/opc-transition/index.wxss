page {
  overflow: hidden;
  background: #f7f1e8;
}

.transition-page {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f1e8;
}

.transition-artboard {
  position: relative;
  width: 100vw;
  height: 150vw;
  max-width: 66.67vh;
  max-height: 100vh;
}

.transition-image {
  width: 100%;
  height: 100%;
}

.transition-button {
  position: absolute;
  right: 37.5%;
  bottom: 4.8%;
  left: 37.5%;
  height: 10%;
  border: 0;
  background: transparent;
  opacity: 0;
}

.transition-button::after {
  border: 0;
}
