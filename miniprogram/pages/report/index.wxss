.report-screen {
  padding-bottom: 72rpx;
}

.key-evidence-card {
  padding: 0 30rpx;
  overflow: hidden;
  border-top: 7rpx solid #df1429;
  border-radius: 24rpx;
}

.key-evidence-header {
  display: flex;
  padding: 27rpx 0 23rpx;
  align-items: center;
  border-bottom: 1rpx solid #e9e4df;
}

.evidence-signal {
  padding: 27rpx 0 25rpx;
}

.evidence-signal-heading {
  display: flex;
  align-items: center;
}

.evidence-signal-icon {
  display: inline-flex;
  width: 46rpx;
  height: 46rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e0172c;
  border-radius: 50%;
  color: #df1429;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
}

.evidence-signal-name {
  margin-left: 15rpx;
  color: #df1429;
  font-size: 29rpx;
  font-weight: 700;
}

.evidence-claims {
  margin-top: 17rpx;
  color: #2f2b29;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.65;
}

.evidence-source-toggle {
  display: flex;
  width: 100%;
  height: 66rpx;
  margin-top: 17rpx;
  align-items: center;
  justify-content: flex-end;
  border-top: 1rpx solid #ece7e2;
  color: #67615d;
  font-size: 22rpx;
  line-height: 1;
}

.evidence-toggle-arrow {
  margin-left: 10rpx;
  color: #8c847e;
  font-size: 30rpx;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.evidence-toggle-arrow.is-expanded {
  transform: rotate(180deg);
}

.evidence-source-list {
  margin-top: 8rpx;
  padding: 4rpx 20rpx;
  border-radius: 14rpx;
  background: #f5f2ef;
}

.evidence-source-item {
  display: flex;
  padding: 17rpx 0;
  align-items: flex-start;
  border-bottom: 1rpx solid #e6e0da;
  color: #706963;
  font-size: 22rpx;
  line-height: 1.6;
}

.evidence-source-item:last-child {
  border-bottom: 0;
}

.evidence-source-id {
  width: 58rpx;
  flex: 0 0 58rpx;
  color: #ca2733;
  font-weight: 650;
}

.evidence-source-quote {
  flex: 1;
}

.evidence-divider {
  height: 1rpx;
  background: #e8e3de;
}

.evidence-empty {
  color: #8c837c;
  font-size: 24rpx;
  line-height: 1.65;
}

.background-strip {
  display: flex;
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  justify-content: space-between;
  border-radius: 16rpx;
  background: #2d2926;
  color: #ffffff;
  font-size: 22rpx;
  gap: 18rpx;
}

.route-heading {
  margin-top: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.route-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.fit-title-row {
  display: flex;
  margin-top: 12rpx;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.fit-title-row .fit-name {
  min-width: 0;
  margin-top: 0;
  flex: 1;
}

.route-id {
  color: #be3a32;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.sufficiency {
  color: #8c837c;
  font-size: 21rpx;
}

.route-name,
.market-name,
.fit-name {
  margin-top: 12rpx;
  color: #2b2724;
  font-size: 34rpx;
  font-weight: 700;
}

.route-one-liner {
  margin-top: 12rpx;
  color: #766e68;
  line-height: 1.6;
}

.detail-row {
  display: flex;
  margin-top: 22rpx;
  align-items: flex-start;
  color: #534c47;
  font-size: 24rpx;
  line-height: 1.6;
  gap: 18rpx;
}

.detail-label {
  width: 110rpx;
  flex: 0 0 auto;
  color: #9a302b;
  font-weight: 600;
}

.risk-row {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #fff0ed;
  color: #8f3831;
  font-size: 23rpx;
  line-height: 1.6;
}

.route-scroll {
  width: calc(100% + 32rpx);
  margin-top: 32rpx;
}

.route-scroll-inner {
  display: flex;
  padding-right: 32rpx;
  gap: 24rpx;
}

.market-card {
  width: 620rpx;
  flex: 0 0 auto;
  padding: 32rpx;
  border: 1rpx solid #e5dcd5;
  border-radius: 26rpx;
  background: #ffffff;
}

.market-field {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eee7e2;
}

.market-field:last-child {
  border-bottom: 0;
}

.market-label {
  color: #9c3630;
  font-size: 21rpx;
  font-weight: 650;
}

.market-value {
  margin-top: 8rpx;
  color: #312d2a;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
}

.market-basis {
  margin-top: 8rpx;
  color: #8b837c;
  font-size: 21rpx;
  line-height: 1.55;
}

.scroll-tip {
  margin-top: 18rpx;
  color: #968d85;
  font-size: 21rpx;
  text-align: center;
}

.condition-card {
  position: relative;
  overflow: hidden;
}

.condition-index {
  position: absolute;
  top: 18rpx;
  right: 24rpx;
  color: #eadfda;
  font-size: 54rpx;
  font-weight: 750;
}

.picker-row {
  display: flex;
  min-height: 86rpx;
  padding: 20rpx 0;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eee7e2;
  color: #554e49;
  font-size: 24rpx;
  gap: 20rpx;
}

.picker-row:last-child {
  border-bottom: 0;
}

.picker-value {
  color: #ac3932;
  font-weight: 600;
  text-align: right;
}

.large-picker {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #dfd5ce;
  border-radius: 16rpx;
  background: #faf8f6;
  color: #a43630;
  font-weight: 600;
}

.static-note {
  margin-top: 24rpx;
  color: #8c837c;
  font-size: 21rpx;
  line-height: 1.6;
}

.fit-result {
  display: flex;
  min-width: 148rpx;
  min-height: 62rpx;
  padding: 13rpx 24rpx;
  flex: 0 0 auto;
  align-self: flex-start;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.status-text {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 650;
}

.status-green { background: #e4f3e9; color: #287448; }
.status-yellow { background: #fff1cf; color: #8b6413; }
.status-red { background: #fde3df; color: #a13a32; }
.status-gray { background: #ece9e6; color: #77706a; }

.dimension-grid {
  margin-top: 26rpx;
}

.dimension-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee7e2;
}

.dimension-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #443e3a;
  font-size: 25rpx;
  font-weight: 600;
}

.dimension-reason {
  margin-top: 10rpx;
  color: #817972;
  font-size: 22rpx;
  line-height: 1.55;
}

.gap-box {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f4f0ed;
  color: #5d5550;
  font-size: 23rpx;
  line-height: 1.6;
}

.gap-label {
  margin-right: 14rpx;
  color: #a53630;
  font-weight: 650;
}

.fit-conclusion {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #f5f1ec;
  color: #302d2b;
  font-size: 27rpx;
  line-height: 1.65;
}

.recommendation {
  margin-top: 12rpx;
}

.route-select-button {
  display: flex;
  width: 100%;
  height: 84rpx;
  margin-top: 24rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #c83f36;
  border-radius: 16rpx;
  color: #b43731;
  font-size: 27rpx;
  font-weight: 650;
}
